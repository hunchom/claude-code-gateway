# Copy to /etc/ccgate/ccgate.env and restrict it: chmod 600, owned by root.
# This file is read by the systemd unit's EnvironmentFile directive.

# Password for the client .p12 (never store this in config.yaml or git).
CCGW_P12_PASSWORD=

# Optional overrides — otherwise set these in /etc/ccgate/config.yaml:
# CCGW_UPSTREAM=https://litellm.internal.example.com
# CCGW_P12_PATH=/etc/ccgate/client.p12
